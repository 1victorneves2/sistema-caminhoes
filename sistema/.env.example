# ========== DATABASE ==========
# URL completa de conexão com o PostgreSQL
# Formato: postgresql://usuario:senha@host:porta/nome_do_banco
DATABASE_URL=postgresql://usuario:senha@localhost:5432/sistema_caminhoes

# Número máximo de conexões simultâneas no pool (padrão: 10)
DATABASE_POOL_SIZE=10

# ========== JWT ==========
# Chave secreta usada para assinar e verificar os tokens JWT
# OBRIGATÓRIO: troque por uma string longa e aleatória em produção
JWT_SECRET=sua_chave_super_secreta_aqui_mude_em_producao

# Tempo de expiração do token (ex: 24h, 7d, 30m)
JWT_EXPIRES_IN=24h

# ========== SERVER ==========
# Porta em que o servidor HTTP vai escutar
PORT=3000

# Ambiente de execução: development | production | test
NODE_ENV=development

# ========== LOGGING ==========
# Nível de detalhe dos logs: error | warn | info | debug
LOG_LEVEL=debug

# ========== CORS ==========
# Origem permitida para requisições cross-origin
# Em produção, substitua pelo domínio real da aplicação
CORS_ORIGIN=http://localhost:3000

# ========== OPTIONAL ==========

# EMAIL (para notificações futuras — não implementado ainda)
# Servidor SMTP para envio de e-mails
SMTP_HOST=smtp.gmail.com

# Porta SMTP: 587 (TLS) ou 465 (SSL)
SMTP_PORT=587

# Credenciais do remetente
SMTP_USER=seu_email@gmail.com
SMTP_PASS=sua_senha_de_app
